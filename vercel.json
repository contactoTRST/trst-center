{
  "rewrites": [
    {
      "source": "/analyze",
      "destination": "/analyze.html"
    }
  ],
  "functions": {
    "api/analyze.js": {
      "maxDuration": 30,
      "memory": 1024
    }
  },
  "headers": [
    {
      "source": "/api/(.*)",
      "headers": [
        {
          "key": "x-vercel-max-request-body-size",
          "value": "20mb"
        }
      ]
    }
  ]
}